{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SSL Training",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/training/train_ssl.py",
      "args": ["--config", "configs/ssl_config.yaml"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Fine-tune",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/training/train_finetune.py",
      "args": ["--config", "configs/finetune_config.yaml"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Preprocessing",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/data_utils/preprocess.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Viz Runner",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/visualization/viz_runner.py",
      "args": ["--checkpoint", "checkpoints/finetune/best_finetune.pth"],
      "console": "integratedTerminal"
    }
  ]
}
